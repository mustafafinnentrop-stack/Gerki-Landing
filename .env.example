# ============================================================
# GERKI LANDING PAGE — ENVIRONMENT VARIABLES
# Kopiere diese Datei als .env.local für lokale Entwicklung
# In Vercel: alle Variablen unter Settings → Environment Variables
# ============================================================

# --- Supabase PostgreSQL ---
# Session Pooler (für Vercel/Serverless — IPv4)
DATABASE_URL="postgresql://postgres.XXXX:PASSWORT@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?pgbouncer=true"
# Direct Connection (für prisma db push / Migrationen)
DIRECT_URL="postgresql://postgres:PASSWORT@db.XXXX.supabase.co:5432/postgres"

# --- NextAuth ---
NEXTAUTH_SECRET=""       # Generieren: openssl rand -base64 32
NEXTAUTH_URL="https://www.gerki.app"

# --- Google OAuth ---
GOOGLE_CLIENT_ID=""      # Google Cloud Console → OAuth 2.0 Client
GOOGLE_CLIENT_SECRET=""

# --- Gerki Desktop App JWT ---
APP_JWT_SECRET=""        # Generieren: openssl rand -base64 32

# --- Stripe ---
STRIPE_SECRET_KEY=""            # Stripe Dashboard → API Keys → Secret key (sk_live_...)
STRIPE_WEBHOOK_SECRET=""        # Stripe Dashboard → Webhooks → Signing secret (whsec_...)
STRIPE_PRICE_STANDARD=""        # Stripe Dashboard → Products → Standard Plan → Price ID (price_...)
STRIPE_PRICE_PRO=""             # Stripe Dashboard → Products → Pro Plan → Price ID (price_...)
STRIPE_PRICE_BUSINESS=""        # Stripe Dashboard → Products → Business Plan → Price ID (price_...)

# --- Groq API (Chat / Llama 3.3 70B) ---
GROQ_API_KEY=""          # console.groq.com → API Keys
